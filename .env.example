# ─── Copy this to .env and fill values ───────────────
# .env is gitignored and never committed

# Database (from Neon.tech)
DB_URL=jdbc:postgresql://ep-xxxx.ap-south-1.aws.neon.tech/school_db?sslmode=require
DB_USERNAME=your_neon_username
DB_PASSWORD=your_neon_password

# JWT
JWT_SECRET=generate-a-256-bit-random-secret-key-here

# Mail (from Resend.com)
RESEND_API_KEY=re_xxxxxxxxxxxx
MAIL_FROM=noreply@yourschoolapp.com

# App
SPRING_PROFILE=dev
# Super Admin
SUPER_ADMIN_EMAIL=your_admin_email
SUPER_ADMIN_PASSWORD=your_admin_pswd